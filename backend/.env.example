# Database
DATABASE_URL=postgresql+pg8000://user:password@localhost:5432/sgeap
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=sgeap

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# App
APP_NAME=SGEAP
APP_VERSION=0.1.0
DEBUG=true